<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">

    <!-- Verifica che ogni file inizi con l'header corretto -->
    <module name="RegexpHeader">
        <property name="header" value="////////////////////////////////////////////////////////////////////\n// Yi Ming Ye 2137995\n// Luca Stangherlin 2137996\n////////////////////////////////////////////////////////////////////"/>
    </module>

    <!-- Lunghezza massima di un file: default 2000 righe -->
    <module name="FileLength"/>

    <!-- Vieta l'uso di tab: si usano solo spazi -->
    <module name="FileTabCharacter"/>

    <!-- Lunghezza massima di una riga -->
    <module name="LineLength">
        <property name="max" value="120"/>
    </module>

    <module name="TreeWalker">

        <!-- Complessità delle espressioni booleane -->
        <module name="BooleanExpressionComplexity"/>

        <!-- Complessità ciclomatica massima: 3 -->
        <module name="CyclomaticComplexity">
            <property name="max" value="10"/>
        </module>

        <!-- Lunghezza massima di un metodo: default 150 righe -->
        <module name="MethodLength"/>

        <!-- Vieta i blocchi catch vuoti -->
        <module name="EmptyCatchBlock"/>

        <!-- Vieta import con wildcard (es. import java.util.*) -->
        <module name="AvoidStarImport"/>

        <!-- Vieta import di package non consentiti (es. sun.*) -->
        <module name="IllegalImport"/>

        <!-- Obbliga le parentesi graffe per if/for/while/do -->
        <module name="NeedBraces"/>

    </module>

</module>